<Window x:Class="Pks_1kr.Views.BookEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование книги" Height="400" Width="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow" ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Название -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" Margin="5" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="TitleBox" Margin="5" 
                 Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                 VerticalAlignment="Center" Padding="3"/>
        
        <!-- ISBN -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="ISBN:" Margin="5" VerticalAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="IsbnBox" Margin="5" 
                 Text="{Binding ISBN, UpdateSourceTrigger=PropertyChanged}" 
                 VerticalAlignment="Center" Padding="3"/>
        
        <!-- Год издания -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Год издания:" Margin="5" VerticalAlignment="Center"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="YearBox" Margin="5" 
                 Text="{Binding PublishYear, UpdateSourceTrigger=PropertyChanged}" 
                 VerticalAlignment="Center" Padding="3"/>
        
        <!-- Количество -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Количество:" Margin="5" VerticalAlignment="Center"/>
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="QuantityBox" Margin="5" 
                 Text="{Binding QuantityInStock, UpdateSourceTrigger=PropertyChanged}" 
                 VerticalAlignment="Center" Padding="3"/>
        
        <!-- Автор -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Автор:" Margin="5" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="4" Grid.Column="1" x:Name="AuthorCombo" Margin="5" 
                  DisplayMemberPath="FullName" SelectedValuePath="Id"
                  SelectedValue="{Binding AuthorId}" 
                  VerticalAlignment="Center" Padding="3"/>
        
        <!-- Жанр -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Жанр:" Margin="5" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="5" Grid.Column="1" x:Name="GenreCombo" Margin="5" 
                  DisplayMemberPath="Name" SelectedValuePath="Id"
                  SelectedValue="{Binding GenreId}" 
                  VerticalAlignment="Center" Padding="3"/>
        
        <!-- Кнопки -->
        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Content="OK" Width="80" Height="30" Margin="5" Padding="5" 
                    IsDefault="True" Click="OkButton_Click"/>
            <Button Content="Отмена" Width="80" Height="30" Margin="5" Padding="5" 
                    IsCancel="True" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>